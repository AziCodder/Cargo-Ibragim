# Авторизация (JWT)
JWT_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Telegram-бот
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
API_BASE_URL=http://localhost:8800

# Уведомления (fallback chat_id, если у накладной нет привязанного клиента с Telegram)
TELEGRAM_CHAT_ID=

# Админ: секрет для /logs и /delete_all_project (только для user id 1338143348)
DELETE_ALL_SECRET=

# CORS: через запятую, например https://yourdomain.com (если фронт на другом домене)
CORS_ORIGINS=

# S3 (Hostkey и др.) — для файлов накладных и бэкапов
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=us-east-1
